# ---------------------------------------------------------------------------
# Snippd web (Vite) — client-exposed vars MUST start with VITE_
# ---------------------------------------------------------------------------

# Public Sentry DSN (safe to ship in the bundle).
VITE_SENTRY_DSN=https://PUBLIC_KEY@oORG.ingest.us.sentry.io/PROJECT_ID

# Release / version tag (git SHA or semver). Sentry ties errors -> releases.
VITE_APP_VERSION=

# Supabase client config (anon key is safe for browser).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ---------------------------------------------------------------------------
# Neo4j Aura — behavioral-intelligence graph (instance 43e46705).
# The browser never reads these; it just POSTs to the ingest-behavior
# edge function at VITE_SNIPPD_BEHAVIOR_URL. The edge function holds the
# password and writes to the graph.
#
# If VITE_SNIPPD_BEHAVIOR_URL is empty the SDK will derive it from
# VITE_SUPABASE_URL as https://<project>.functions.supabase.co/ingest-behavior
# ---------------------------------------------------------------------------
VITE_SNIPPD_BEHAVIOR_URL=

# ---------------------------------------------------------------------------
# Account-deletion edge function endpoint.
# Apple guideline 5.1.1(v): Settings → Delete my account posts here to
# wipe the auth row, user-scoped tables, and the Neo4j graph.
# If empty, the client derives <VITE_SUPABASE_URL>/functions/v1/delete-account.
# Deploy via: supabase functions deploy delete-account
# ---------------------------------------------------------------------------
VITE_SNIPPD_DELETE_ACCOUNT_URL=

# Edge-function-side secrets (set via `supabase secrets set …`, not .env):
#   NEO4J_URI="neo4j+s://43e46705.databases.neo4j.io"
#   NEO4J_USERNAME="neo4j"
#   NEO4J_PASSWORD="<from Aura console — rotated via Aura UI>"
#   NEO4J_DATABASE="neo4j"
#
# The same four vars are also read by scripts/neo4j_smoke.mjs when you
# run `npm run neo4j:smoke` locally to verify the connection.
NEO4J_URI=
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j

# ---------------------------------------------------------------------------
# Stripe — Snippd Pro ($4.99/mo).
# The Price ID + publishable key are public-safe. The secret key lives ONLY
# on the Checkout Session endpoint (Supabase Edge Function or similar).
# ---------------------------------------------------------------------------
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_or_test_...
VITE_STRIPE_PRICE_SNIPPD_PRO=price_...
# POST endpoint that mints a Checkout Session server-side using the secret key.
# Expected response: { "url": "https://checkout.stripe.com/..." }
VITE_STRIPE_CHECKOUT_URL=https://<project>.functions.supabase.co/create-checkout-session

# ---------------------------------------------------------------------------
# Build-time ONLY — never ship to the browser. Used by vite.config.js to
# upload source maps to Sentry in production builds.
# ---------------------------------------------------------------------------

SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=sntrys_...

# ---------------------------------------------------------------------------
# Vertex ADK agent (snippd_agent/.env) — server-side only.
# These NEVER belong in the web bundle.
# ---------------------------------------------------------------------------

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
VERTEX_AGENT_MODEL=gemini-2.5-flash
SNIPPD_STORES=walmart,aldi,target,publix,sprouts,cvs,walgreens,trader_joes,bravo,sav_a_lot,key_foods

# Optional: override the LLM-safe column projection for stack_candidates.
# Defaults are in snippd_agent/tools/supabase_tool.py :: _DEFAULT_STACK_CANDIDATES_COLUMNS.
# Any column in the PII denylist is stripped regardless of this override.
# STACK_CANDIDATES_LLM_COLUMNS=id,store_id,product_name,brand,sale_price,discount_pct

# Agent-side Sentry (separate project recommended).
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# ---------------------------------------------------------------------------
# Slack — communication hub for app status.
#
# RECOMMENDED: set ONE webhook (SLACK_WEBHOOK_URL) pointed at the channel
# you use as your main comms hub. Every workflow falls back to this if no
# channel-specific webhook is set. Posts get inline topic tags like
# [action-needed], [win], [report], [app-review], [provision] so you can
# scan one channel and tell them apart.
#
# Setup (~2 minutes):
#   1. In Slack: Apps → "Incoming Webhooks" → Add to Slack → pick the hub channel
#   2. Copy the webhook URL (starts https://hooks.slack.com/services/...)
#   3. GitHub repo → Settings → Secrets and variables → Actions →
#      New repository secret → name: SLACK_WEBHOOK_URL, value: <the URL>
#   4. Run the "slack-smoketest" workflow to verify delivery
#
# After that, you can fan out later if you want dedicated channels for
# #wins or #app-review — set SLACK_WINS_WEBHOOK_URL / etc. below and those
# override the hub for that specific topic.
# ---------------------------------------------------------------------------
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T000/B000/XXXX

# Optional channel-specific overrides. Leave unset to route to SLACK_WEBHOOK_URL.
SLACK_WINS_WEBHOOK_URL=

# Optional: dedicated channel webhooks. If unset, the workflows that post
# reports / founder actions / Apple-review audit results route to the
# shared SLACK_WEBHOOK_URL hub defined above.
SLACK_REPORTS_WEBHOOK_URL=
SLACK_ACTIONS_WEBHOOK_URL=
SLACK_APP_REVIEW_WEBHOOK_URL=

# ---------------------------------------------------------------------------
# Supabase-triggered Slack notifications (retailer policy changes)
#
# Unlike the GitHub Actions webhooks above, the retailer policy change
# notifier is configured INSIDE Supabase (not as a GitHub secret).
#
# Setup (~2 minutes):
#   1. In Slack: Apps → "Incoming Webhooks" → toggle ON → Add New Webhook
#      → pick the channel (e.g. #engineering)
#   2. Copy the webhook URL (starts https://hooks.slack.com/services/...)
#   3. Run: scripts/setup-slack-webhook.sh "<the URL>"
#
# This stores the webhook in public.snippd_integrations (service-role only).
# The Postgres trigger (notify_retailer_policy_change) reads it and posts
# real-time notifications on every policy insert/update/delete via pg_net.
#
# To disable: UPDATE snippd_integrations SET is_enabled = false
#             WHERE name = 'slack_policy_changes';
# ---------------------------------------------------------------------------
