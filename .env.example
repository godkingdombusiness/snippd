# ---------------------------------------------------------------------------
# Snippd web (Vite) — client-exposed vars MUST start with VITE_
# ---------------------------------------------------------------------------

# Public Sentry DSN (safe to ship in the bundle).
VITE_SENTRY_DSN=https://PUBLIC_KEY@oORG.ingest.us.sentry.io/PROJECT_ID

# Release / version tag (git SHA or semver). Sentry ties errors -> releases.
VITE_APP_VERSION=

# Supabase client config (anon key is safe for browser).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ---------------------------------------------------------------------------
# Neo4j Aura — behavioral-intelligence graph (instance 43e46705).
# The browser never reads these; it just POSTs to the ingest-behavior
# edge function at VITE_SNIPPD_BEHAVIOR_URL. The edge function holds the
# password and writes to the graph.
#
# If VITE_SNIPPD_BEHAVIOR_URL is empty the SDK will derive it from
# VITE_SUPABASE_URL as https://<project>.functions.supabase.co/ingest-behavior
# ---------------------------------------------------------------------------
VITE_SNIPPD_BEHAVIOR_URL=

# Edge-function-side secrets (set via `supabase secrets set …`, not .env):
#   NEO4J_URI="neo4j+s://43e46705.databases.neo4j.io"
#   NEO4J_USERNAME="neo4j"
#   NEO4J_PASSWORD="<from Aura console — rotated via Aura UI>"
#   NEO4J_DATABASE="neo4j"
#
# The same four vars are also read by scripts/neo4j_smoke.mjs when you
# run `npm run neo4j:smoke` locally to verify the connection.
NEO4J_URI=
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j

# ---------------------------------------------------------------------------
# Stripe — Snippd Pro ($4.99/mo).
# The Price ID + publishable key are public-safe. The secret key lives ONLY
# on the Checkout Session endpoint (Supabase Edge Function or similar).
# ---------------------------------------------------------------------------
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_or_test_...
VITE_STRIPE_PRICE_SNIPPD_PRO=price_...
# POST endpoint that mints a Checkout Session server-side using the secret key.
# Expected response: { "url": "https://checkout.stripe.com/..." }
VITE_STRIPE_CHECKOUT_URL=https://<project>.functions.supabase.co/create-checkout-session

# ---------------------------------------------------------------------------
# Build-time ONLY — never ship to the browser. Used by vite.config.js to
# upload source maps to Sentry in production builds.
# ---------------------------------------------------------------------------

SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=sntrys_...

# ---------------------------------------------------------------------------
# Vertex ADK agent (snippd_agent/.env) — server-side only.
# These NEVER belong in the web bundle.
# ---------------------------------------------------------------------------

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
VERTEX_AGENT_MODEL=gemini-2.5-flash
SNIPPD_STORES=walmart,aldi,target,publix,sprouts,cvs,walgreens,trader_joes,bravo,sav_a_lot,key_foods

# Optional: override the LLM-safe column projection for stack_candidates.
# Defaults are in snippd_agent/tools/supabase_tool.py :: _DEFAULT_STACK_CANDIDATES_COLUMNS.
# Any column in the PII denylist is stripped regardless of this override.
# STACK_CANDIDATES_LLM_COLUMNS=id,store_id,product_name,brand,sale_price,discount_pct

# Agent-side Sentry (separate project recommended).
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# ---------------------------------------------------------------------------
# Slack #wins channel — auto-celebration broadcaster.
# Create an Incoming Webhook bound to #wins:
#   Slack workspace → Apps → "Incoming Webhooks" → Add to Slack → #wins
# Then drop the URL here AND as a GitHub Actions repo secret of the same name
# so .github/workflows/wins.yml can post on every merge to main.
# ---------------------------------------------------------------------------
SLACK_WINS_WEBHOOK_URL=https://hooks.slack.com/services/T000/B000/XXXX

# ---------------------------------------------------------------------------
# Slack #reports channel — @Reporter heartbeat cadence.
# 6 posts/day (1am / 5am / 9am / 11am / 3pm / 8pm ET) summarizing npm audit,
# open PRs, recent merges to main, CI status, and the founder-queue count.
# Same setup flow as #wins and #founder-actions: create channel, bind an
# Incoming Webhook, paste URL here AND as a GitHub Actions repo secret.
# Workflow: .github/workflows/reports-cron.yml
# ---------------------------------------------------------------------------
SLACK_REPORTS_WEBHOOK_URL=https://hooks.slack.com/services/T000/B000/XXXX

# ---------------------------------------------------------------------------
# Slack #founder-actions channel — autonomous-agent queue of things only the
# founder can do (secret rotations, dashboard toggles, Stripe Price IDs, etc.).
# Canonical backlog lives at .snippd/founder-actions.json.
# scripts/sync_founder_actions.mjs renders the current queue + open PRs.
# Same setup flow as #wins: create the channel, add an Incoming Webhook,
# paste the URL here AND as a GitHub Actions repo secret of the same name
# so .github/workflows/founder-actions-sync.yml can auto-post on PR events.
# ---------------------------------------------------------------------------
SLACK_ACTIONS_WEBHOOK_URL=https://hooks.slack.com/services/T000/B000/XXXX

# ---------------------------------------------------------------------------
# Slack #app-review channel — Apple Reviewer audit heartbeat.
# Create a second Incoming Webhook bound to #app-review, then add to repo
# secrets as SLACK_APP_REVIEW_WEBHOOK_URL so the weekly App Review audit
# (.github/workflows/app-review-audit.yml) posts to Slack.
# Run locally with: npm run audit:app-review:dry
# ---------------------------------------------------------------------------
SLACK_APP_REVIEW_WEBHOOK_URL=https://hooks.slack.com/services/T000/B000/XXXX
