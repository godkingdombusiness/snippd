# Expo / client configuration
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key

# Supabase service role configuration (server-side only)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional ingestion secret for unauthenticated event writes
INGEST_API_KEY=your-ingest-api-key

# Optional cron secret for scheduled functions
WEEKLY_REFRESH_CRON_SECRET=your-weekly-refresh-cron-secret
PREFERENCE_UPDATER_CRON_SECRET=your-preference-updater-cron-secret
