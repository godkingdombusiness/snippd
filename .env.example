# ============================================================
# Snippd — Environment Variables Reference
# Copy to .env and fill in real values. NEVER commit .env.
# ============================================================

# ── Supabase (React Native / Expo) ───────────────────────────
EXPO_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# ── Supabase (Node.js services) ──────────────────────────────
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# ── Neo4j (Memory Graph) ─────────────────────────────────────
# Used by: src/services/graphSync.ts, src/lib/neo4jClient.ts
NEO4J_URI=neo4j+s://<host>:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=<password>
NEO4J_DATABASE=neo4j

# ── Vertex AI ────────────────────────────────────────────────
# Used by: src/services/vertexFeatureBuilder.ts
VERTEX_ENDPOINT_URL=https://<region>-aiplatform.googleapis.com/v1/projects/<project>/locations/<region>/endpoints/<endpoint>
VERTEX_API_KEY=<google-cloud-api-key>

# ── Gemini ───────────────────────────────────────────────────
# Used by: supabase/functions/gemini-proxy/index.ts
GEMINI_API_KEY=<gemini-api-key>

# ── Model versioning ─────────────────────────────────────────
MODEL_VERSION=v1.0.0

# ── Ingest auth (server-to-server event writes) ───────────────
INGEST_API_KEY=<random-hex-secret>

# ── Cron auth ─────────────────────────────────────────────────
# Set as Edge Function secret: npx supabase secrets set CRON_SECRET=<value>
# Also stored in vault.secrets as 'snippd_cron_secret' (for pg_cron)
CRON_SECRET=<64-char-hex>

# ── GitHub (run-graph-sync workflow_dispatch) ─────────────────
# Used by: supabase/functions/run-graph-sync/index.ts
GITHUB_PAT=<github-personal-access-token>
GITHUB_OWNER=<github-org-or-user>
GITHUB_REPO=<repo-name>
